+            }
+        }
+
+        let cancelled = ZwzV3MemoryKeyProvider()
+        cancelled.lookupError = ZwzV3Error.userAuthenticationCancelled
+        XCTAssertThrowsError(try ZwzV3Extractor().listEntries(
+            archivePath: fixture.archive.path,
