+            at: tempDir,
+            withIntermediateDirectories: true
+        )
+        let errorFile = tempDir.appendingPathComponent("error.txt")
+        try? error.localizedDescription.write(
+            to: errorFile,
+            atomically: true,
+            encoding: .utf8
+        )
+        return errorFile
+    }
